<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Allow only access via direct fetch (no directory listing)
  Options -Indexes
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/json M0
</IfModule>
# Tests Directory - Public on GitHub
# Password protection removed for public repository

# Security headers
<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>

# Disable directory listing
Options -Indexes
